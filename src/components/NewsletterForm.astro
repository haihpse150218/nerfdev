---
// Buttondown form — no JS needed, pure HTML form POST
---

<div class="newsletter-box">
  <h3 class="newsletter-title">Stay in the loop</h3>
  <p class="newsletter-desc">New posts, no spam. Unsubscribe anytime.</p>
  <form
    action="https://buttondown.com/api/emails/embed-subscribe/nerfdev"
    method="post"
    target="_blank"
    class="newsletter-form"
  >
    <input
      type="email"
      name="email"
      placeholder="your@email.com"
      required
      class="newsletter-input"
    />
    <button type="submit" class="newsletter-btn">Subscribe</button>
  </form>
  <p class="newsletter-note">
    Powered by <a href="https://buttondown.com" target="_blank" rel="noopener">Buttondown</a>
  </p>
</div>

<style>
  .newsletter-box {
    max-width: 420px;
    margin: 0 auto;
  }

  .newsletter-title {
    font-size: 1.15rem;
    margin-bottom: var(--space-xs);
  }

  .newsletter-desc {
    color: var(--clr-muted);
    font-size: 0.9rem;
    margin-bottom: var(--space-lg);
  }

  .newsletter-form {
    display: flex;
    gap: var(--space-sm);
  }

  .newsletter-input {
    flex: 1;
    padding: 0.6rem 1rem;
    border-radius: var(--radius-md);
    border: 1px solid var(--clr-border);
    background: var(--clr-surface);
    color: var(--clr-text);
    font-family: var(--font-mono);
    font-size: 0.85rem;
    outline: none;
    transition: border-color var(--transition);
  }

  .newsletter-input:focus {
    border-color: var(--clr-accent);
  }

  .newsletter-input::placeholder {
    color: var(--clr-muted);
  }

  .newsletter-btn {
    padding: 0.6rem 1.25rem;
    border-radius: var(--radius-md);
    border: none;
    background: var(--clr-accent);
    color: var(--clr-bg);
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.85rem;
    cursor: pointer;
    transition: background var(--transition);
  }

  .newsletter-btn:hover {
    background: var(--clr-accent-hover);
  }

  .newsletter-note {
    font-size: 0.7rem;
    color: var(--clr-muted);
    margin-top: var(--space-sm);
    text-align: center;
  }

  .newsletter-note a {
    color: var(--clr-accent);
    text-decoration: underline;
  }

  @media (max-width: 480px) {
    .newsletter-form {
      flex-direction: column;
    }
  }
</style>
