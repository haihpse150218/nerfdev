---
interface Props {
  post: any;
  featured?: boolean;
}

const { post, featured = false } = Astro.props;
const { title, description, publishedDate, tags, minutesRead } = post.data;
const date = new Date(publishedDate).toLocaleDateString("en-US", {
  month: "short",
  day: "numeric",
});
---

<a href={`/blog/${post.slug}/`} class:list={["post-card", { featured }]}>
  <div class="card-meta">
    <time>{date}</time>
    {minutesRead && <span class="read-time">{minutesRead}m</span>}
  </div>
  <h3 class="card-title">{title}</h3>
  <p class="card-desc">{description}</p>
  <div class="card-tags">
    {tags.map((tag: string) => (
      <span class="tag">#{tag}</span>
    ))}
  </div>
</a>

<style>
  .post-card {
    display: block;
    padding: var(--space-lg);
    border-radius: var(--radius-md);
    border: 1px solid var(--clr-border);
    background: var(--clr-surface);
    transition: all var(--transition);
  }

  .post-card:hover {
    border-color: var(--clr-accent);
    background: var(--clr-surface-hover);
    transform: translateY(-1px);
  }

  .post-card.featured {
    border-color: var(--clr-accent);
    background: var(--clr-accent-dim);
  }

  .card-meta {
    display: flex;
    gap: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--clr-muted);
    margin-bottom: var(--space-sm);
  }

  .card-title {
    font-size: 1.15rem;
    margin-bottom: var(--space-xs);
    color: var(--clr-heading);
    line-height: 1.3;
  }

  .card-desc {
    font-size: 0.9rem;
    color: var(--clr-muted);
    line-height: 1.5;
    margin-bottom: var(--space-sm);
  }

  .card-tags {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--clr-accent);
    opacity: 0.7;
  }
</style>
